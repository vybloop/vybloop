# --- GitHub App (preferred) ---
# When GITHUB_APP_ID is set and the private key is present, the app authenticates
# as the "VybLoop" GitHub App. Users grant repo access by installing the app on
# GitHub (no token to paste). Leave these unset to fall back to PAT mode below.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Path *inside the container* to the .pem (mounted via docker-compose.yml).
GITHUB_APP_PRIVATE_KEY_PATH=/secrets/vybloop.pem

# --- Personal Access Token (fallback) ---
# Used only when no GitHub App is configured above.
GITHUB_TOKEN=your_token_here
